# ─── Beacon ──────────────────────────────────────────────────────────────────

# Beacon HTTP server port.
# Default: 3000
PORT=3000

# Public base URL the beacon is reachable at. Used to compose the
# /.well-known/agent-card.json `url` and additionalInterfaces[] entries.
# Default: http://localhost:3000
BEACON_BASE_URL=http://localhost:3000

# Comma-separated list of host headers the MCP transport will accept.
# DNS-rebinding protection rejects everything else.
# Default: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Anthropic API key. Required for humancard_score_opportunity (LLM-backed
# scoring). All other tools work without it.
# Default: (unset)
ANTHROPIC_API_KEY=

# Anthropic model id used by the scoring engine.
# Default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Scoring ─────────────────────────────────────────────────────────────────
# (Scoring uses ANTHROPIC_API_KEY / ANTHROPIC_MODEL above. No extra vars.)

# ─── x402 payments ───────────────────────────────────────────────────────────

# Recipient EVM address for x402 payments (0x + 40 hex chars). When unset,
# premium tools (humancard_score_opportunity) run free — keeps local dev
# zero-config. Set this in production to gate the premium tool.
# Default: (unset, premium tools free)
X402_PAY_TO=

# CAIP-2 chain id for x402 settlement. Allowed values:
#   eip155:84532  — Base Sepolia testnet
#   eip155:8453   — Base mainnet
# Default: eip155:84532
X402_NETWORK=eip155:84532

# Public hosted x402 facilitator URL.
# Default: https://x402.org/facilitator
X402_FACILITATOR_URL=https://x402.org/facilitator

# Price per call to humancard_score_opportunity, e.g. "$0.01".
# Default: $0.01
X402_SCORE_PRICE=$0.01

# ─── DID-WBA identity ────────────────────────────────────────────────────────

# Hex-encoded Ed25519 private key used to sign A2A requests and to publish
# the verification method in /.well-known/did.json. Generate with
# `openssl rand -hex 32`. When unset, did:wba identity is disabled.
# Default: (unset)
DIDWBA_PRIVATE_KEY_HEX=

# ─── Hunter ──────────────────────────────────────────────────────────────────

# Cron schedule for the Hunter run loop. Standard 5-field cron syntax.
# Default: 0 */2 * * *   (every 2 hours, on the hour)
HUNTER_CRON_SCHEDULE=0 */2 * * *

# Comma-separated keyword list used to filter inbound job-board listings.
# Default: agentic,ai,mcp,langchain
HUNTER_KEYWORDS=agentic,ai,mcp,langchain

# Comma-separated ATS board identifiers in <provider>:<slug> form.
# Supported providers: greenhouse, lever, ashby. Empty disables the source.
# Example: greenhouse:anthropic,ashby:openai,greenhouse:vercel
# Default: (empty)
HUNTER_ATS_BOARDS=

# Outbound webhook for scored job alerts. Discord/Slack-compatible JSON.
# Default: (unset, alerts logged only)
WEBHOOK_URL=

# Path for the Hunter dedup state file.
# Default: .hunter-state.json
HUNTER_STATE_FILE=.hunter-state.json

# ─── Logging ─────────────────────────────────────────────────────────────────

# DEV-ONLY: bypass the alert.ts SSRF guard (allows http:// and loopback/private
# hosts as WEBHOOK_URL targets). Never enable in production — the guard exists
# to prevent outbound probes to internal services and cloud metadata endpoints.
# Default: false
HUNTER_ALLOW_INSECURE_WEBHOOK=false

# Logger verbosity: debug | info | warn | error.
# Default: info
LOG_LEVEL=info

# ─── On-chain (TESTNET) ─────────────────────────────────────────────────────

# Base Sepolia RPC. Public default works for low volume; use Alchemy/Infura
# for anything production-grade.
# Default: https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer / attestor signing key. TESTNET ONLY — generate a fresh keypair
# (`openssl rand -hex 32` or viem's generatePrivateKey()) and fund it from
# a Base Sepolia faucet. Never put a mainnet-funded key here.
# Default: (unset)
DEPLOYER_PRIVATE_KEY=

# Public address derived from DEPLOYER_PRIVATE_KEY. Optional convenience
# field; helpful when configuring faucets / exploring on Basescan.
# Default: (unset)
DEPLOYER_ADDRESS=
